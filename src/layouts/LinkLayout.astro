---
import BaseLayout, { type LayoutHeadProps } from "./BaseLayout.astro";

interface Props extends LayoutHeadProps {
  bodyClass?: string;
}

const { bodyClass = "", ...head } = Astro.props;
const classes = ["linkbeam-link", bodyClass].filter(Boolean).join(" ");
---

<BaseLayout {...head} surface="link" bodyClass={classes}>
  <slot />
</BaseLayout>

<style>
  .linkbeam-link,
  :global(.beamlink-link) {
    min-height: 100dvh;
  }

  :global(body.linkbeam-link--preview-pane),
  :global(body.beamlink-link--preview-pane) {
    min-height: 100%;
    height: 100%;
    overflow: hidden;
  }

  :global(html:has(body.linkbeam-link--preview-pane)),
  :global(html:has(body.beamlink-link--preview-pane)) {
    height: 100%;
  }
</style>
