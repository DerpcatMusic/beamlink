---
import AppLayout from "@layouts/AppLayout.astro";
import AdminLinkNav from "@components/AdminLinkNav.astro";
import Button from "@components/Button.astro";
import Chart from "@components/Chart.astro";
import HourHeatmap from "@components/HourHeatmap.astro";
import CollapsibleSection from "@components/CollapsibleSection.astro";
import AnalyticsAudience from "@components/AnalyticsAudience.astro";
import AnalyticsAttribution from "@components/AnalyticsAttribution.astro";
import AnalyticsMetaDelivery from "@components/AnalyticsMetaDelivery.astro";
import Icon from "@components/Icon.astro";
import PlatformIcon from "@components/PlatformIcon.astro";
import SettingsModal from "@components/SettingsModal.astro";
import SubscriberManager from "@components/SubscriberManager.astro";
import { getLinkById, listSubscribers } from "@lib/db";
import { getRuntimeEnv, requireAdmin, publicBaseUrl } from "@lib/runtime";
import { effectiveLinkMode, daysUntilRelease } from "@lib/effective-mode";
import {
  getAdBreakdown,
  getBrowserBreakdown,
  getCampaignBreakdown,
  getCityBreakdown,
  getDeviceBreakdown,
  getFunnelStats,
  getGeoBreakdown,
  getHourHeatmap,
  getHourlyTimeseries,
  getLinkCampaignAttribution,
  getLinkTimeseries,
  getOsBreakdown,
  getPlacementBreakdown,
  getPlatformClicks,
  getReferrerBreakdown,
  getUniqueTimeseries,
  getUniqueVisitors,
  normalizeAnalyticsOptions
} from "@lib/stats";
import { artworkPublicPath } from "@lib/artwork";
import { platformBrandColors } from "@lib/platform-brand";
import { getMetaAccessToken, getMetaAdAccountId, getMetaConversionValue, getMetaCurrency, getMetaPixelId } from "@lib/settings";
import {
  countSentCapiConversions,
  countSentCapiByEventName,
  getCapiDeliveryStats,
  listCapiLogsByLink
} from "@lib/capi-log";
import { getMetaDatasetQuality } from "@lib/meta-quality";
import {
  buildCampaignPerformance,
  getMetaAdsInsights,
  resolveCampaignNames
} from "@lib/meta-ads-insights";
import { resolveClickEventName, resolveViewEventName } from "@lib/effective-mode";
import { platformLabels } from "@lib/types";
import { sectionResult } from "@lib/analytics-loader";

const env = getRuntimeEnv(Astro);
const blocked = await requireAdmin(Astro.request, env);
if (blocked) return blocked;

const link = await getLinkById(env, Astro.params.id ?? "");
if (!link) return Astro.redirect("/admin", 302);
const subscribers = await listSubscribers(env, link.id);

const baseUrl = publicBaseUrl(env, Astro.request).replace(/\/$/, "");
const publicUrl = `${baseUrl}/${link.slug}`;
const previewUrl = `${publicUrl}?preview=1`;
const options = normalizeAnalyticsOptions(Astro.url.searchParams);
const isHourly = options.granularity === "hourly";
const conversionValue = getMetaConversionValue(env);
const currency = getMetaCurrency(env);
const clickEventName = resolveClickEventName(link);
const viewEventName = resolveViewEventName(link);
const metaDays = isHourly ? Math.max(1, Math.ceil(options.hours / 24)) : options.days;
const [coreSection, audienceSection, attributionSection, metaSection] = await Promise.all([
  sectionResult("core", async () => {
    const [funnel, timeseries, heatmap, uniqueVisitors] = await Promise.all([
      getFunnelStats(env, link.id, options.days),
      isHourly ? getHourlyTimeseries(env, link.id, options.hours) : options.unique ? getUniqueTimeseries(env, link.id, options.days) : getLinkTimeseries(env, link.id, options.days),
      getHourHeatmap(env, link.id, options.days),
      getUniqueVisitors(env, link.id, options.days)
    ]);
    return { funnel, timeseries, heatmap, uniqueVisitors };
  }),
  sectionResult("audience", async () => {
    const [platformClicks, geoRows, cityRows, deviceRows, browserRows, osRows] = await Promise.all([
      getPlatformClicks(env, link.id), getGeoBreakdown(env, link.id, options.days), getCityBreakdown(env, link.id, options.days),
      getDeviceBreakdown(env, link.id, options.days), getBrowserBreakdown(env, link.id, options.days), getOsBreakdown(env, link.id, options.days)
    ]);
    return { platformClicks, geoRows, cityRows, deviceRows, browserRows, osRows };
  }),
  sectionResult("attribution", async () => {
    const [campaignRows, linkCampaignAttribution, adRows, placementRows, referrerRows, metaAccessToken, metaAdAccountId] = await Promise.all([
      getCampaignBreakdown(env, link.id, metaDays), getLinkCampaignAttribution(env, link.id, metaDays), getAdBreakdown(env, link.id, metaDays),
      getPlacementBreakdown(env, link.id, metaDays), getReferrerBreakdown(env, link.id, metaDays), getMetaAccessToken(env), getMetaAdAccountId(env)
    ]);
    const metaAdsInsights = metaAdAccountId && metaAccessToken ? await getMetaAdsInsights(env, metaDays, clickEventName) : null;
    const campaignNameOverrides = await resolveCampaignNames(env, linkCampaignAttribution.map((row) => row.campaignId).filter(Boolean));
    return { campaignRows, adRows, placementRows, referrerRows, metaAdsInsights, campaignPerformance: buildCampaignPerformance(linkCampaignAttribution, metaAdsInsights, campaignNameOverrides), configured: Boolean(metaAdAccountId && metaAccessToken) };
  }),
  sectionResult("meta", async () => {
    const [pixelId, metaAccessToken, logs, delivery, sentConversions, sentCurrentEvent, sentLegacyEvent, quality] = await Promise.all([
      getMetaPixelId(env), getMetaAccessToken(env), listCapiLogsByLink(env, link.id, 20, options.days), getCapiDeliveryStats(env, link.id, options.days),
      countSentCapiConversions(env, link.id, options.days, clickEventName), countSentCapiByEventName(env, link.id, clickEventName, options.days),
      countSentCapiByEventName(env, link.id, "Stream_Click", options.days), getMetaDatasetQuality(env)
    ]);
    return { pixelId, hasAccessToken: Boolean(metaAccessToken), logs, delivery, sentConversions, sentCurrentEvent, sentLegacyEvent, quality };
  })
]);
const core = coreSection.ok ? coreSection.value : null;
const audience = audienceSection.ok ? audienceSection.value : null;
const attribution = attributionSection.ok ? attributionSection.value : null;
const campaignPerformance = attribution?.campaignPerformance ?? [];
const campaignDisplayRows = campaignPerformance.map((row) => ({
  label: row.displayName,
  count: row.yourTaps,
  share: (core?.funnel.viewContents ?? 0) > 0 ? row.yourTaps / core!.funnel.viewContents : 0
}));
const totalAdSpend = campaignPerformance.reduce((sum, row) => sum + (row.spend ?? 0), 0);
const adsInsightsCurrency = attribution?.metaAdsInsights?.currency ?? currency;
const tapRateLabel = core && core.funnel.pageViews > 0 ? `${(core.funnel.tapRate * 100).toFixed(1)}%` : "—";
const rangeLabel = isHourly
  ? (options.hours === 168 ? "Last 7 days · hourly" : `Last ${options.hours}h`)
  : `Last ${options.days} days`;
const uniqueLabel = options.unique ? "unique" : "total";
const platformTotal = audience?.platformClicks.reduce((sum, row) => sum + row.clicks, 0) ?? 0;
const platformBreakdownRows = (audience?.platformClicks ?? []).map((row) => ({
  label: platformLabels[row.platform] ?? row.platform,
  count: row.clicks,
  share: platformTotal > 0 ? row.clicks / platformTotal : 0,
  platform: row.platform,
  brandColor: platformBrandColors[row.platform]
}));
const geoBreakdownRows = (audience?.geoRows ?? []).map((row) => ({ label: row.country, count: row.count, share: row.share }));

function formatCurrency(amount: number): string {
  try {
    return new Intl.NumberFormat("en-US", { style: "currency", currency, maximumFractionDigits: 2 }).format(amount);
  } catch {
    return `${amount.toFixed(2)} ${currency}`;
  }
}
const effectiveMode = effectiveLinkMode(link);
const days = daysUntilRelease(link.track.release_at);
const artistLabel = link.track.artist_name || "Unknown artist";
const artworkSrc = artworkPublicPath(link.track);
const modeBadge = effectiveMode === "presave"
  ? { label: `Pre-save${days !== null ? ` · ${days}d` : ""}`, variant: "presave" }
  : { label: "Live", variant: "live" };
const identityBadges = [modeBadge, { label: link.status, variant: link.status }];
const isDraft = link.status === "draft";
const directStreamLinks = link.destinations.map((destination) => ({
  platform: destination.platform,
  label: platformLabels[destination.platform] ?? destination.label,
  url: `${baseUrl}/d/${link.slug}/${destination.platform}`
}));

function hrefWith(overrides: Record<string, string>, removes: string[] = []): string {
  const params = new URLSearchParams(Astro.url.searchParams);
  for (const key of removes) params.delete(key);
  for (const [key, value] of Object.entries(overrides)) params.set(key, value);
  return `?${params.toString()}`;
}

---

<AppLayout title={link.link_name}>
  <main class="admin-page shell">
    <AdminLinkNav
      linkId={link.id}
      slug={link.slug}
      linkName={link.link_name}
      trackTitle={link.track.title}
      artistName={artistLabel}
      activeTab="overview"
      artworkSrc={artworkSrc}
      badges={identityBadges}
    />

    <section class="action-bar" aria-label="Link actions">
      <div class="url-bar">
        <code data-sensitive>{publicUrl}</code>
        <Button variant="secondary" size="sm" id="copyUrl" type="button" aria-label="Copy public URL"><Icon name="copy" /> Copy</Button>
      </div>
      <div class="admin-toolbar action-buttons">
        <Button variant="accent" href={publicUrl} target="_blank" rel="noreferrer"><Icon name="open" /> Open link</Button>
        <Button variant="secondary" href={`/admin/links/${link.id}/edit`}><Icon name="edit" /> Edit</Button>
        <Button class="danger" id="deleteButton" type="button"><Icon name="trash" /> Delete</Button>
      </div>
    </section>

    {directStreamLinks.length > 0 && (
      <section class="section direct-links" aria-label="Direct stream links">
        <div class="panel-head">
          <h2 class="section-title">Direct stream links</h2>
        </div>
        <div class="direct-link-list">
          {directStreamLinks.map((item) => (
            <div class="direct-link-row">
              <span class="name"><PlatformIcon platform={item.platform} size={18} tint /><span>{item.label}</span></span>
              <code>{item.url}</code>
              <Button variant="secondary" size="sm" type="button" data-copy-url={item.url}>Copy</Button>
            </div>
          ))}
        </div>
      </section>
    )}

    {core ? (<>
    <section class="admin-panel analytics-panel" aria-label="Analytics">
      <div class="metric-strip bare funnel-strip" aria-label="Funnel">
        <div class="metric">
          <span class="label">Page views</span>
          <span class="value accent">{core.funnel.pageViews}</span>
          <span class="sub muted">{rangeLabel} · {uniqueLabel}</span>
        </div>
        <div class="funnel-arrow" aria-hidden="true">→</div>
        <div class="metric">
          <span class="label">Stream taps</span>
          <span class="value success">{core.funnel.viewContents}</span>
          <span class="sub muted">
            {totalAdSpend > 0
              ? `Ad spend ${formatCurrency(totalAdSpend)}`
              : `CAPI ${formatCurrency(conversionValue)} / tap`}
          </span>
        </div>
        <div class="metric">
          <span class="label">Tap rate</span>
          <span class="value">{tapRateLabel}</span>
          <span class="sub muted">Views → taps</span>
        </div>
        <div class="metric">
          <span class="label">Unique visitors</span>
          <span class="value">{core.uniqueVisitors}</span>
          <span class="sub muted">Deduped people</span>
        </div>
      </div>

      <div class="panel-head chart-head">
        <div class="chart-title">
          <h2>Traffic over time</h2>
          <p class="muted panel-subtitle">
            {isHourly ? "Hourly" : "Daily"} · {rangeLabel.toLowerCase()} · {uniqueLabel} counts
          </p>
        </div>
        <div class="chart-controls analytics-toolbar">
          <div class="range-toggle" aria-label="Granularity">
            <a class:list={["range", !isHourly && "active"]} href={hrefWith({ granularity: "daily" }, ["hours"])} aria-current={!isHourly ? "true" : undefined}>Daily</a>
            <a class:list={["range", isHourly && "active"]} href={hrefWith({ granularity: "hourly" })} aria-current={isHourly ? "true" : undefined}>Hourly</a>
          </div>
          {isHourly ? (
            <div class="range-toggle" aria-label="Hour range">
              {([24, 48, 168] as const).map((hours) => (
                <a class:list={["range", options.hours === hours && "active"]} href={hrefWith({ granularity: "hourly", hours: String(hours) })} aria-current={options.hours === hours ? "true" : undefined}>{hours === 168 ? "7d" : `${hours}h`}</a>
              ))}
            </div>
          ) : (
            <div class="range-toggle" aria-label="Day range">
              {([7, 30, 90] as const).map((range) => (
                <a class:list={["range", options.days === range && "active"]} href={hrefWith({ granularity: "daily", range: String(range) }, ["hours"])} aria-current={options.days === range ? "true" : undefined}>{range}d</a>
              ))}
            </div>
          )}
          {!isHourly && (
            <div class="range-toggle" aria-label="Count mode">
              <a class:list={["range", !options.unique && "active"]} href={hrefWith({ unique: "0" })} aria-current={!options.unique ? "true" : undefined}>Total</a>
              <a class:list={["range", options.unique && "active"]} href={hrefWith({ unique: "1" })} aria-current={options.unique ? "true" : undefined}>Unique</a>
            </div>
          )}
        </div>
      </div>
      <Chart
        series={core.timeseries}
        labelFormat={isHourly ? "hour" : "day"}
        viewsLabel="Page views"
        clicksLabel="Stream taps"
        showDelta={!isHourly}
        ariaLabel={`Traffic chart for ${link.link_name}, ${rangeLabel}`}
      />
    </section>

    <CollapsibleSection id="peak-hours" title="Peak hours" subtitle={`ViewContent taps · ${rangeLabel} · UTC`} defaultOpen={true}>
      <HourHeatmap data={core.heatmap} ariaLabel={`Taps by hour and weekday for ${link.link_name}`} />
    </CollapsibleSection>
    </>) : (
      <section class="admin-panel section-unavailable" role="status"><h2>Analytics unavailable</h2><p class="muted">{coreSection.ok ? "Analytics data is temporarily unavailable." : coreSection.message}</p></section>
    )}

    {audience ? (
      <AnalyticsAudience rangeLabel={rangeLabel} platformRows={platformBreakdownRows} countryRows={geoBreakdownRows} cityRows={audience.cityRows} deviceRows={audience.deviceRows} browserRows={audience.browserRows} osRows={audience.osRows} />
    ) : (
      <CollapsibleSection id="audience" title="Audience" subtitle="Temporarily unavailable" defaultOpen={true}><p class="muted empty-line">{audienceSection.ok ? "Analytics data is temporarily unavailable." : audienceSection.message}</p></CollapsibleSection>
    )}

    {attribution ? (
      <AnalyticsAttribution rangeLabel={rangeLabel} configured={attribution.configured} campaignPerformance={campaignPerformance} currency={adsInsightsCurrency} metaError={attribution.metaAdsInsights?.error} metaFetchedAt={attribution.metaAdsInsights?.fetchedAt} campaignRows={campaignDisplayRows.length > 0 ? campaignDisplayRows : attribution.campaignRows} adRows={attribution.adRows} placementRows={attribution.placementRows} referrerRows={attribution.referrerRows} />
    ) : (
      <CollapsibleSection id="attribution" title="Attribution" subtitle="Temporarily unavailable" defaultOpen={false}><p class="muted empty-line">{attributionSection.ok ? "Analytics data is temporarily unavailable." : attributionSection.message}</p></CollapsibleSection>
    )}

    {metaSection.ok ? (
      <AnalyticsMetaDelivery rangeLabel={rangeLabel} pixelId={metaSection.value.pixelId} hasAccessToken={metaSection.value.hasAccessToken} logs={metaSection.value.logs} delivery={metaSection.value.delivery} sentConversions={metaSection.value.sentConversions} sentCurrentEvent={metaSection.value.sentCurrentEvent} sentLegacyEvent={metaSection.value.sentLegacyEvent} trackedTaps={core?.funnel.viewContents ?? 0} clickEventName={clickEventName} viewEventName={viewEventName} quality={metaSection.value.quality} />
    ) : (
      <CollapsibleSection id="meta-delivery" title="Meta delivery & quality" subtitle="Temporarily unavailable" defaultOpen={false}><p class="muted empty-line">{metaSection.message}</p></CollapsibleSection>
    )}


    <SubscriberManager linkId={link.id} subscribers={subscribers} />

    <section class="section footer-actions">
      <div class="admin-toolbar">
        {isDraft && <Button variant="accent" id="publishButton" type="button">Publish link</Button>}
        <Button variant="secondary" href={previewUrl} target="_blank" rel="noreferrer"><Icon name="open" /> Draft preview</Button>
        <Button variant="secondary" href={`/api/admin/links/${link.id}/subscribers`}>Export subscribers</Button>
        {!isDraft && <Button variant="secondary" id="publishButton" type="button">Republish</Button>}
        <Button variant="ghost" id="archiveButton" type="button"><Icon name="archive" /> Archive</Button>
      </div>
      <p class="muted action-status" id="actionStatus" aria-live="polite"></p>
    </section>
  </main>

  <SettingsModal />

  <script is:inline define:vars={{ linkId: link.id, publicUrl, trackId: link.track_id, linkName: link.link_name, slug: link.slug, mode: link.mode, destinations: JSON.stringify(Object.fromEntries(link.destinations.map((d) => [d.platform, d.url]))) }}>
    const copyUrl = document.querySelector("#copyUrl");
    const actionStatus = document.querySelector("#actionStatus");
    const publishButton = document.querySelector("#publishButton");
    const archiveButton = document.querySelector("#archiveButton");
    const deleteButton = document.querySelector("#deleteButton");

    copyUrl?.addEventListener("click", async () => {
      await navigator.clipboard.writeText(publicUrl);
      copyUrl.textContent = "Copied";
      setTimeout(() => { copyUrl.textContent = "Copy"; }, 1200);
    });

    for (const button of document.querySelectorAll("[data-copy-url]")) {
      button.addEventListener("click", async () => {
        const value = button.dataset.copyUrl;
        if (!value) return;
        await navigator.clipboard.writeText(value);
        const label = button.textContent || "Copy";
        button.textContent = "Copied";
        setTimeout(() => { button.textContent = label; }, 1200);
      });
    }

    publishButton?.addEventListener("click", async () => {
      actionStatus.textContent = "Publishing…";
      const response = await fetch(`/api/admin/links/${linkId}/publish`, { method: "POST" });
      const data = await response.json();
      actionStatus.textContent = response.ok
        ? `Published at /${data.link.slug}.`
        : data.error || "Publish failed.";
    });

    archiveButton?.addEventListener("click", async () => {
      actionStatus.textContent = "Archiving…";
      const response = await fetch(`/api/admin/links/${linkId}`, {
        method: "PATCH",
        headers: { "content-type": "application/json" },
        body: JSON.stringify({
          trackId,
          linkName,
          slug,
          mode,
          destinations: JSON.parse(destinations),
          status: "archived"
        })
      });
      const data = await response.json();
      actionStatus.textContent = response.ok ? "Archived." : data.error || "Archive failed.";
    });

    deleteButton?.addEventListener("click", async () => {
      const confirmed = prompt(`Delete “${linkName}”? This removes the link and its analytics. Type DELETE to continue.`);
      if (confirmed !== "DELETE") return;
      const response = await fetch(`/api/admin/links/${linkId}`, { method: "DELETE" });
      if (response.ok) {
        window.location.href = "/admin";
        return;
      }
      const data = await response.json().catch(() => ({}));
      actionStatus.textContent = data.error || "Delete failed.";
    });
  </script>
</AppLayout>

<style>
  .action-bar {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .action-bar .url-bar {
    flex: 1 1 20rem;
  }

  .action-buttons {
    gap: 0.4rem;
  }

  .direct-links {
    gap: 0.65rem;
  }

  .direct-link-list {
    display: grid;
  }

  .direct-link-row {
    display: grid;
    grid-template-columns: minmax(8rem, 12rem) minmax(0, 1fr) auto;
    align-items: center;
    gap: 0.75rem;
    min-height: 2.75rem;
    padding-block: 0.5rem;
    border-top: 1px solid var(--border);
  }

  .direct-link-row:last-child {
    border-bottom: 1px solid var(--border);
  }

  .direct-link-row .name {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    min-width: 0;
    color: var(--foreground);
    font-size: var(--text-sm);
    font-weight: 600;
  }

  .direct-link-row .name span:last-child,
  .direct-link-row code {
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .direct-link-row code {
    color: var(--muted);
    font-family: var(--mono);
    font-size: var(--text-sm);
  }

  .analytics-panel {
    gap: 1.15rem;
    padding: 0;
    overflow: visible;
  }

  /* Metrics as the panel's header row, edge-to-edge with a bottom hairline. */
  .metric-strip.bare {
    border: 0;
    border-bottom: 1px solid var(--border);
    border-radius: var(--radius-lg) var(--radius-lg) 0 0;
    background: color-mix(in oklch, var(--surface-2) 35%, transparent);
    box-shadow: none;
    overflow: hidden;
  }

  .chart-head {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    justify-content: space-between;
    gap: 0.75rem 1rem;
    padding-inline: 1.25rem;
  }

  .analytics-panel :global(.chart-wrap) {
    padding: 0.15rem 1.25rem 1.35rem;
  }

  .chart-title {
    min-width: min(100%, 12rem);
  }

  .chart-title h2 {
    margin: 0;
    font-size: var(--text-base);
    font-weight: 650;
    letter-spacing: -0.015em;
    text-wrap: balance;
  }

  .panel-subtitle {
    margin: 0.2rem 0 0;
    font-size: var(--text-xs);
    line-height: 1.4;
    color: var(--muted);
  }

  .range-toggle {
    display: inline-flex;
    gap: 0.12rem;
    padding: 0.18rem;
    border-radius: var(--radius);
    background: var(--inset);
    border: 1px solid color-mix(in oklch, var(--border) 80%, transparent);
  }

  .range {
    min-height: 1.7rem;
    display: inline-flex;
    align-items: center;
    border-radius: calc(var(--radius-sm) - 1px);
    padding: 0.22rem 0.6rem;
    color: var(--muted);
    font-size: var(--text-xs);
    font-weight: 600;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.01em;
    transition: background-color var(--transition-fast), color var(--transition-fast), box-shadow var(--transition-fast);
  }

  .range:hover {
    color: var(--foreground);
  }

  .range.active {
    background: var(--surface-2);
    color: var(--foreground);
    box-shadow: var(--shadow-sm);
  }

  .chart-controls,
  .analytics-toolbar {
    display: inline-flex;
    gap: 0.45rem;
    flex-wrap: wrap;
    justify-content: flex-end;
    align-items: center;
  }

  .tech-split {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 14rem), 1fr));
    gap: 1.25rem 2rem;
  }

  .tech-title {
    margin: 0 0 0.5rem;
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--foreground);
  }

  .attribution-hint {
    margin: 0.5rem 0 0;
    font-size: var(--text-xs);
  }

  .tracking-head {
    justify-content: flex-end;
    margin: 0;
  }

  .meta-delivery-strip {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    overflow: hidden;
    background: color-mix(in srgb, var(--surface) 92%, transparent);
  }

  .meta-delivery-strip .metric {
    padding: 0.75rem 0.9rem;
    border-inline-start: 1px solid var(--border);
    border-radius: 0;
    background: transparent;
    box-shadow: none;
  }

  .meta-delivery-strip .metric:first-child {
    border-inline-start: 0;
  }

  .meta-delivery-strip .value {
    font-size: var(--text-xl);
  }

  .meta-delivery-strip .value.success {
    color: var(--success);
  }

  .meta-details {
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 0.65rem 0.9rem;
    background: color-mix(in srgb, var(--surface) 94%, transparent);
  }

  .meta-details-summary {
    cursor: pointer;
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--foreground);
