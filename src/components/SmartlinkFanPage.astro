---
import PlatformIcon from "@components/PlatformIcon.astro";
import { formatShortDate } from "@lib/datetime";
import { parseTrackPalette, paletteStyleAttribute } from "@lib/palette";
import {
  asciiPatternDataUri,
  backgroundClasses,
  buttonClasses,
  platformBrandStyle,
  platformIconTint,
  type ButtonStyle,
  type PageBackgroundStyle
} from "@lib/page-style";
import type { LinkMode, Platform } from "@lib/types";

export interface SmartlinkDestinationRow {
  platform: Platform;
  cta: string;
  href: string;
  trackAttrs?: Record<string, string>;
}

interface Props {
  title: string;
  artistName: string;
  isrc?: string | null;
  artworkUrl: string;
  paletteJson?: string | null;
  releaseAt?: string | null;
  effectiveMode: LinkMode;
  pageBackgroundStyle: PageBackgroundStyle;
  buttonStyle: ButtonStyle;
  destinations: SmartlinkDestinationRow[];
  embedded?: boolean;
  previewPane?: boolean;
  showDraftRibbon?: boolean;
  interactive?: boolean;
}

const {
  title,
  artistName,
  isrc = null,
  artworkUrl,
  paletteJson = null,
  releaseAt = null,
  effectiveMode,
  pageBackgroundStyle,
  buttonStyle,
  destinations,
  embedded = false,
  previewPane = false,
  showDraftRibbon = false,
  interactive = true
} = Astro.props;

const isPresave = effectiveMode === "presave";
const paletteVars = parseTrackPalette(paletteJson);
const iconTint = platformIconTint(buttonStyle);
const safeArtwork = artworkUrl.replace(/["\\\n\r]/g, "");
const asciiPattern = pageBackgroundStyle === "ascii" ? asciiPatternDataUri(paletteVars) : "";
const pageStyle = `${paletteStyleAttribute(paletteVars)}; --artwork-image: url("${safeArtwork}")${asciiPattern ? `; --ascii-pattern: ${asciiPattern}` : ""}`;
const countdownFallback = releaseAt
  ? `Releases ${formatShortDate(releaseAt)}`
  : "Release date coming soon";
---

{showDraftRibbon && (
  <div class="draft-ribbon" role="status">
    Draft preview
  </div>
)}

<main
  class:list={[
    "smart-page",
    backgroundClasses(pageBackgroundStyle),
    buttonClasses(buttonStyle),
    embedded && "smart-page--embedded",
    previewPane && "smart-page--preview-pane"
  ]}
  style={pageStyle}
>
  <div class="page-backdrop" aria-hidden="true">
    <div class="artwork-bg"></div>
    {pageBackgroundStyle === "ascii" && <div class="ascii-overlay"></div>}
    {pageBackgroundStyle === "mesh" && (
      <div class="bg-effect bg-effect--mesh">
        <div class="mesh-base"></div>
        <div class="mesh-orbs">
          <span class="mesh-orb mesh-orb--1"></span>
          <span class="mesh-orb mesh-orb--2"></span>
          <span class="mesh-orb mesh-orb--3"></span>
          <span class="mesh-orb mesh-orb--4"></span>
          <span class="mesh-orb mesh-orb--5"></span>
        </div>
      </div>
    )}
    {pageBackgroundStyle === "aurora" && (
      <div class="bg-effect bg-effect--aurora">
        <span class="aurora-sheet aurora-sheet--a"></span>
        <span class="aurora-sheet aurora-sheet--b"></span>
        <span class="aurora-sheet aurora-sheet--c"></span>
      </div>
    )}
    {pageBackgroundStyle === "vinyl" && (
      <div class="bg-effect bg-effect--vinyl">
        <div class="vinyl-disc">
          <div class="vinyl-grooves"></div>
          <div class="vinyl-shine"></div>
          <div class="vinyl-label"></div>
        </div>
      </div>
    )}
  </div>
  <div class="page-scrim" aria-hidden="true"></div>

  <section class="release">
    <img
      class="artwork"
      src={artworkUrl}
      alt={`${title} cover art`}
      width="640"
      height="640"
      loading="eager"
      decoding="async"
      fetchpriority="high"
    />
    <div class="copy">
      <p class="mode">{isPresave ? "Pre-save" : "Listen now"}</p>
      <h1>{title}</h1>
      <p class="artist">{artistName}</p>
      {isrc && <p class="isrc">ISRC {isrc}</p>}
      {isPresave && (
        <p class="countdown" data-release-at={releaseAt ?? ""} aria-live="polite">
          {countdownFallback}
        </p>
      )}
    </div>
  </section>

  {isPresave && interactive && (
    <form class="subscribe" id="subscribeForm">
      <label for="email">Email for release day reminder</label>
      <div class="subscribe-row">
        <input
          id="email"
          name="email"
          type="email"
          required
          placeholder="you@example.com"
          autocomplete="email"
          inputmode="email"
        />
        <button class="button subscribe-submit" type="submit">Notify me</button>
      </div>
      <p class="subscribe-status muted" id="subscribeStatus" role="status" aria-live="polite"></p>
    </form>
  )}

  <nav class={`destinations count-${destinations.length}`} aria-label="Streaming platforms">
    {destinations.map((row) => (
      <a
        class:list={[
          "destination",
          row.platform === "spotify" && "destination--spotify"
        ]}
        href={row.href}
        data-platform={row.platform}
        style={platformBrandStyle(row.platform)}
        tabindex={interactive ? undefined : -1}
        aria-disabled={interactive ? undefined : "true"}
        {...row.trackAttrs}
      >
        <PlatformIcon platform={row.platform} size={22} tint={iconTint} />
        <span>{row.cta}</span>
        <svg class="chevron" width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 4l6 6-6 6" /></svg>
      </a>
    ))}
  </nav>
</main>

{isPresave && releaseAt && interactive && (
  <script is:inline define:vars={{ releaseAt }}>
    const countdown = document.querySelector(".countdown");
    const target = new Date(releaseAt).getTime();
    if (!Number.isNaN(target)) {
      function tick() {
        const diff = Math.max(0, target - Date.now());
        const days = Math.floor(diff / 86400000);
        const hours = Math.floor((diff % 86400000) / 3600000);
        const minutes = Math.floor((diff % 3600000) / 60000);
        const seconds = Math.floor((diff % 60000) / 1000);
        if (countdown) {
          countdown.textContent = diff <= 0
            ? "Out now"
            : `Releases in ${days}d ${hours}h ${minutes}m ${seconds}s`;
        }
      }
      tick();
      setInterval(tick, 1000);
    }
  </script>
)}

{!interactive && (
  <script is:inline>
    document.querySelectorAll("a.destination").forEach((anchor) => {
      anchor.addEventListener("click", (event) => event.preventDefault());
    });
  </script>
)}

<style>
  .draft-ribbon {
    position: fixed;
    top: 0.75rem;
    left: 50%;
    z-index: 30;
    translate: -50% 0;
    border-radius: 999px;
    padding: 0.35rem 0.85rem;
    background: var(--warn, oklch(0.78 0.15 70));
    color: oklch(0.18 0.02 70);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.01em;
    box-shadow: 0 6px 18px oklch(0 0 0 / 0.28);
  }

  .smart-page {
    position: relative;
    width: min(30rem, calc(100% - 2rem));
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1rem;
    margin-inline: auto;
    padding-block: 1.75rem;
    isolation: isolate;
  }

  :global(.beamlink-link--embedded) {
    min-height: 0;
    overflow: hidden;
    background: var(--background);
  }

  :global(.beamlink-link--preview-pane) {
    min-height: 100%;
    height: 100%;
    overflow: hidden;
    background: var(--background);
  }

  .smart-page--embedded {
    width: min(100% - 1.5rem, 24rem);
    min-height: 0;
    justify-content: start;
    gap: 0.8rem;
    padding-block: 1.25rem;
  }

  .smart-page--preview-pane {
    width: 100%;
    max-width: none;
    min-height: 100%;
    justify-content: start;
    gap: clamp(0.75rem, 2.5vw, 1rem);
    margin-inline: 0;
    padding: clamp(0.85rem, 3.5vw, 1.5rem) clamp(0.85rem, 4vw, 1.25rem) 1.25rem;
    box-sizing: border-box;
  }

  .smart-page--preview-pane .page-backdrop {
    position: absolute;
    inset: -18vmin;
  }

  .smart-page--preview-pane .page-scrim {
    position: absolute;
    inset: 0;
  }

  .page-backdrop {
    position: fixed;
    inset: -7rem;
    z-index: -2;
    overflow: hidden;
    pointer-events: none;
  }

  .smart-page--embedded .page-backdrop {
    position: absolute;
    inset: -4rem -3rem;
  }

  .artwork-bg {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, oklch(0.1 0.01 260 / 0.16), var(--page-tint, var(--background)) 86%),
      var(--artwork-image);
    background-position: center;
    background-size: cover;
    opacity: 0;
    transform: scale(1.12);
  }

  .smart-page--bg-blur .artwork-bg,
  .smart-page--bg-ascii .artwork-bg {
    opacity: 0.95;
    filter: blur(3.8rem) saturate(1.38) brightness(1.22);
  }

  .smart-page--bg-mesh .artwork-bg,
  .smart-page--bg-aurora .artwork-bg,
  .smart-page--bg-vinyl .artwork-bg {
    opacity: 0.48;
    filter: blur(2.6rem) saturate(1.42) brightness(1.14);
    transform: scale(1.1);
  }

  .smart-page--bg-vinyl .artwork-bg {
    mask-image: radial-gradient(circle at 50% var(--vinyl-disc-y, 34%), black 0%, black 22%, transparent 36%);
    opacity: 0.62;
  }

  .smart-page--embedded.smart-page--bg-blur .artwork-bg,
  .smart-page--embedded.smart-page--bg-ascii .artwork-bg {
    filter: blur(3rem) saturate(1.28) brightness(1.14);
    transform: scale(1);
  }

  .smart-page--embedded.smart-page--bg-mesh .artwork-bg,
  .smart-page--embedded.smart-page--bg-aurora .artwork-bg,
  .smart-page--embedded.smart-page--bg-vinyl .artwork-bg {
    filter: blur(2.2rem) saturate(1.32) brightness(1.1);
    transform: scale(1.04);
  }

  .smart-page--bg-ascii .artwork-bg {
    opacity: 0.72;
    filter: blur(1.4rem) saturate(1.25) brightness(0.92) contrast(1.28);
    image-rendering: pixelated;
  }

  .ascii-overlay {
    position: absolute;
    inset: 0;
    background-color: color-mix(in oklch, var(--background) 55%, transparent);
    background-image: var(--ascii-pattern);
    background-size: 200px 160px;
    mix-blend-mode: normal;
    opacity: 1;
  }

  .smart-page--bg-mesh .page-scrim,
  .smart-page--bg-aurora .page-scrim,
  .smart-page--bg-vinyl .page-scrim,
  .smart-page--bg-ascii .page-scrim {
    background:
      linear-gradient(180deg, oklch(0.02 0.006 260 / 0.16), oklch(0.02 0.006 260 / 0.34)),
      oklch(0.06 0.01 260 / 0.28);
  }

  .bg-effect {
    position: absolute;
    inset: 0;
    overflow: hidden;
    isolation: isolate;
  }

  /* --- Mesh: Aceternity-style animated orbs --- */
  .bg-effect--mesh {
    --mesh-orb-size: clamp(11rem, 52vmin, 30rem);
  }

  .mesh-base {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      155deg,
      color-mix(in oklch, var(--background) 45%, var(--page-tint)),
      var(--background) 72%
    );
  }

  .mesh-orbs {
    position: absolute;
    inset: -22%;
    filter: blur(3.2rem);
  }

  .mesh-orb {
    position: absolute;
    width: var(--mesh-orb-size);
    height: var(--mesh-orb-size);
    top: calc(50% - var(--mesh-orb-size) / 2);
    left: calc(50% - var(--mesh-orb-size) / 2);
    border-radius: 50%;
    mix-blend-mode: hard-light;
    opacity: 0.88;
    will-change: transform;
  }

  .mesh-orb--1 {
    background: radial-gradient(circle, color-mix(in oklch, var(--primary) 72%, var(--page-tint)) 0%, transparent 58%);
    transform-origin: center;
    animation: mesh-float-y 28s cubic-bezier(0.25, 1, 0.5, 1) infinite;
  }

  .mesh-orb--2 {
    background: radial-gradient(circle, color-mix(in oklch, var(--page-tint) 82%, var(--primary)) 0%, transparent 56%);
    transform-origin: calc(50% - 14vmin);
    animation: mesh-orbit 22s cubic-bezier(0.22, 1, 0.36, 1) infinite reverse;
  }

  .mesh-orb--3 {
    background: radial-gradient(circle, color-mix(in oklch, var(--primary) 58%, transparent) 0%, transparent 62%);
    transform-origin: calc(50% + 12vmin);
    animation: mesh-sway 26s cubic-bezier(0.25, 1, 0.5, 1) infinite;
  }

  .mesh-orb--4 {
    background: radial-gradient(circle, color-mix(in oklch, var(--page-tint) 68%, var(--surface)) 0%, transparent 60%);
    transform-origin: calc(50% - 8vmin) calc(50% + 10vmin);
    animation: mesh-orbit 32s cubic-bezier(0.22, 1, 0.36, 1) infinite;
  }

  .mesh-orb--5 {
    background: radial-gradient(circle, color-mix(in oklch, var(--primary) 48%, var(--page-tint)) 0%, transparent 64%);
    transform-origin: calc(50% + 16vmin) calc(50% - 6vmin);
    animation: mesh-float-y 24s cubic-bezier(0.25, 1, 0.5, 1) infinite reverse;
  }

  @keyframes mesh-float-y {
    0%, 100% { transform: translateY(-16%) scale(1); }
    50% { transform: translateY(16%) scale(1.06); }
  }

  @keyframes mesh-orbit {
    0% { transform: rotate(0deg) scale(1); }
    50% { transform: rotate(180deg) scale(1.08); }
    100% { transform: rotate(360deg) scale(1); }
  }

  @keyframes mesh-sway {
    0%, 100% { transform: translate(-14%, -10%) scale(1); }
    50% { transform: translate(14%, 10%) scale(1.05); }
  }

  /* --- Aurora: elliptical drifting sheets --- */
  .bg-effect--aurora {
    background: linear-gradient(
      168deg,
      color-mix(in oklch, var(--background) 62%, transparent),
      color-mix(in oklch, var(--page-tint) 42%, var(--background))
    );
  }

  .aurora-sheet {
    position: absolute;
    width: 200%;
    height: 200%;
    top: -50%;
    left: -50%;
    border-radius: 50%;
    filter: blur(3.6rem);
    mix-blend-mode: screen;
    opacity: 0.78;
    will-change: transform;
  }

  .aurora-sheet--a {
    background:
      radial-gradient(ellipse 82% 48% at 48% 8%, color-mix(in oklch, var(--primary) 62%, transparent) 0%, transparent 68%),
      radial-gradient(ellipse 58% 38% at 28% 18%, color-mix(in oklch, var(--page-tint) 55%, transparent) 0%, transparent 62%);
    animation: aurora-wave 20s cubic-bezier(0.25, 1, 0.5, 1) infinite;
  }

  .aurora-sheet--b {
    background:
      radial-gradient(ellipse 74% 42% at 72% 12%, color-mix(in oklch, var(--page-tint) 58%, var(--primary)) 0%, transparent 64%);
    animation: aurora-wave 20s cubic-bezier(0.25, 1, 0.5, 1) infinite;
    animation-delay: -10s;
  }

  .aurora-sheet--c {
    background:
      radial-gradient(ellipse 68% 36% at 40% 22%, color-mix(in oklch, var(--primary) 42%, var(--page-tint)) 0%, transparent 58%);
    opacity: 0.55;
    filter: blur(4.2rem);
    animation: aurora-drift-c 26s cubic-bezier(0.22, 1, 0.36, 1) infinite alternate;
  }

  @keyframes aurora-wave {
    0%, 100% { transform: translate(0, 0) rotate(0deg) scale(1); }
    25% { transform: translate(4%, -3%) rotate(5deg) scale(1.04); }
    50% { transform: translate(-3%, 4%) rotate(-4deg) scale(1.08); }
    75% { transform: translate(2%, -2%) rotate(2deg) scale(1.03); }
  }

  @keyframes aurora-drift-c {
    from { transform: translate(-6%, 4%) scale(0.96); }
    to { transform: translate(8%, -5%) scale(1.06); }
  }

  /* --- Vinyl: true circular disc --- */
  .bg-effect--vinyl {
    --vinyl-disc-y: 34%;
    --vinyl-size: min(128vmin, 40rem);
  }

  .vinyl-disc {
    position: absolute;
    left: 50%;
    top: var(--vinyl-disc-y);
    translate: -50% -50%;
    width: var(--vinyl-size);
    aspect-ratio: 1;
    border-radius: 50%;
    overflow: hidden;
    mask-image: radial-gradient(circle, #000 64%, transparent 78%);
  }

  .vinyl-grooves {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: repeating-radial-gradient(
      circle at center,
      transparent 0 1.3px,
      color-mix(in oklch, var(--foreground) 20%, transparent) 1.3px 2.2px
    );
    opacity: 0.92;
  }

  .vinyl-shine {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: conic-gradient(
      from 205deg,
      transparent 0deg,
      oklch(1 0 0 / 0.08) 32deg,
      oklch(1 0 0 / 0.04) 52deg,
      transparent 78deg,
      transparent 198deg,
      oklch(1 0 0 / 0.06) 222deg,
      transparent 258deg
    );
    mix-blend-mode: soft-light;
    pointer-events: none;
  }

  .vinyl-label {
    position: absolute;
    inset: 33%;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      color-mix(in oklch, var(--page-tint) 78%, var(--primary)) 0%,
      color-mix(in oklch, var(--page-tint) 38%, var(--background)) 100%
    );
    box-shadow: 0 0 0 1px oklch(0 0 0 / 0.22) inset;
  }

  .smart-page--preview-pane .bg-effect--mesh {
    --mesh-orb-size: clamp(8rem, 62vmin, 22rem);
  }

  .smart-page--preview-pane .mesh-orbs {
    filter: blur(2.4rem);
  }

  .smart-page--preview-pane .bg-effect--vinyl {
    --vinyl-size: min(135vmin, 26rem);
  }

  .page-scrim {
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    background:
      linear-gradient(180deg, oklch(0.02 0.006 260 / 0.28), oklch(0.02 0.006 260 / 0.6)),
      oklch(0.06 0.01 260 / calc(var(--scrim-opacity, 0.72) * 0.62));
  }

  .smart-page--embedded .page-scrim {
    position: absolute;
    inset: -1.5rem;
  }

  .release {
    display: grid;
    justify-items: center;
    gap: 1rem;
    width: 100%;
    text-align: center;
  }

  .artwork {
    width: min(74vw, 20rem);
    height: auto;
    aspect-ratio: 1;
    object-fit: cover;
    border-radius: 16px;
    background: var(--surface);
    box-shadow:
      0 1px 0 oklch(1 0 0 / 0.12) inset,
      0 0 0 1px oklch(0 0 0 / 0.35),
      0 24px 60px -18px oklch(0 0 0 / 0.7);
  }

  .smart-page--preview-pane .release {
    gap: clamp(0.65rem, 2vw, 0.9rem);
  }

  .smart-page--preview-pane .artwork {
    width: min(72vw, 100%);
    max-width: 100%;
    border-radius: clamp(12px, 2.5vw, 16px);
  }

  .smart-page--preview-pane .copy {
    width: 100%;
    max-width: none;
  }

  .smart-page--preview-pane h1 {
    max-width: none;
    font-size: clamp(1.35rem, 5.8vw, 2rem);
  }

  .smart-page--preview-pane .destinations {
    margin-top: 0;
  }

  .smart-page--preview-pane .release,
  .smart-page--preview-pane .subscribe,
  .smart-page--preview-pane .destinations,
  .smart-page--preview-pane .artwork {
    animation: none !important;
  }

  .smart-page--embedded .artwork {
    width: min(58vw, 13rem);
    height: min(58vw, 13rem);
    border-radius: 14px;
  }

  .copy {
    display: grid;
    gap: 0.4rem;
    min-width: 0;
    max-width: 22rem;
  }

  .mode,
  .isrc,
  .artist,
  .countdown {
    margin: 0;
  }

  .mode {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
  }

  h1 {
    margin: 0;
    max-width: 15ch;
    font-size: clamp(1.65rem, 5.4vw, 2.35rem);
    line-height: 1.08;
    letter-spacing: -0.03em;
    text-wrap: balance;
    overflow-wrap: anywhere;
  }

  .smart-page--embedded h1 {
    font-size: clamp(1.45rem, 8vw, 1.9rem);
  }

  .artist {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--foreground);
  }

  .isrc,
  .countdown {
    font-size: 0.8rem;
    color: var(--muted);
  }

  .subscribe {
    display: grid;
    gap: 0.55rem;
    width: 100%;
  }

  .subscribe label {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--foreground);
  }

  .subscribe-row {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 0.5rem;
  }

  .subscribe-row input {
    min-width: 0;
    min-height: 2.75rem;
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 0.65rem 0.75rem;
    background: var(--surface);
    color: var(--foreground);
    transition: border-color 180ms ease, background-color 180ms ease;
  }

  .subscribe-row input::placeholder {
    color: var(--muted);
    opacity: 1;
  }

  .subscribe-submit {
    border-radius: 12px;
    transition: transform 180ms ease, filter 180ms ease;
  }

  .subscribe-submit:hover {
    filter: brightness(1.04);
  }

  .subscribe-status {
    margin: 0;
    min-height: 1.2rem;
    font-size: 0.8rem;
  }

  .destinations {
    display: grid;
    gap: 0.55rem;
    width: 100%;
    margin-top: 0.15rem;
  }

  .destination {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 0.8rem;
    min-height: 3.5rem;
    padding: 0.72rem 0.95rem 0.72rem 0.9rem;
    border-radius: 14px;
    border: 1px solid oklch(0.98 0.004 265 / 0.14);
    background: oklch(0.22 0.006 265 / 0.55);
    color: var(--foreground);
    font-size: 0.95rem;
    font-weight: 600;
    backdrop-filter: blur(14px) saturate(1.1);
    transition:
      transform 180ms ease,
      background-color 180ms ease,
      border-color 180ms ease;
  }

  .smart-page--embedded .destination {
    min-height: 3.2rem;
    padding-block: 0.62rem;
    border-radius: 12px;
    font-size: 0.9rem;
  }

  .destination > span {
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .destination .chevron {
    flex-shrink: 0;
