---
import AppLayout from "@layouts/AppLayout.astro";

interface Props {
  title: string;
  backHref?: string;
  backLabel?: string;
  lede?: string;
  fullWidth?: boolean;
  showHeader?: boolean;
}

const {
  title,
  backHref = "/admin",
  backLabel = "All links",
  lede,
  fullWidth = true,
  showHeader = true
} = Astro.props;
---

<AppLayout title={title} fullWidth={fullWidth}>
  <main class="link-editor">
    <slot name="top" />

    {showHeader && (
      <header class="link-editor__header">
        <div>
          {backHref && (
            <a class="back" href={backHref}>
              <svg width="14" height="14" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 4l-6 6 6 6" /></svg>
              {backLabel}
            </a>
          )}
          <h1>{title}</h1>
          {lede && <p class="lede">{lede}</p>}
        </div>
        <slot name="header-actions" />
      </header>
    )}

    <div class="link-editor__split">
      <div class="link-editor__form">
        <slot />
      </div>

      <aside class="link-editor__preview" aria-label="Live preview">
        <div class="preview-chrome">
          <span class="preview-label">Live preview</span>
          <span class="preview-hint muted">Updates as you edit</span>
        </div>
        <div class="preview-frame-wrap">
          <iframe
            id="linkPreviewFrame"
            title="Fan smartlink preview"
            loading="lazy"
            sandbox="allow-scripts allow-same-origin"
          ></iframe>
        </div>
      </aside>
    </div>
  </main>

  <slot name="scripts" />
</AppLayout>

<style>
  .link-editor {
    display: grid;
    gap: 0.75rem;
    width: calc(100% - clamp(1.25rem, 3vw, 2rem));
    max-width: none;
    margin-inline: auto;
    padding-block: 0.85rem 1.25rem;
    min-height: calc(100dvh - 2.5rem);
  }

  .link-editor__header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .link-editor__header h1 {
    margin: 0;
    font-size: var(--text-2xl);
    font-weight: 720;
    letter-spacing: -0.02em;
    line-height: 1.15;
  }

  .lede {
    margin: 0.35rem 0 0;
    max-width: 42ch;
    font-size: var(--text-sm);
    color: var(--muted);
  }

  .back {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    margin-bottom: 0.5rem;
    color: var(--muted);
    font-size: var(--text-sm);
    font-weight: 500;
    transition: color var(--transition-fast);
  }

  .back:hover {
    color: var(--foreground);
  }

  .link-editor__split {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: clamp(0.85rem, 2vw, 1.35rem);
    align-items: stretch;
    min-height: calc(100dvh - 7rem);
    flex: 1;
  }

  .link-editor__form {
    display: grid;
    gap: 0;
    align-content: start;
    min-width: 0;
    min-height: 0;
    max-height: calc(100dvh - 6.5rem);
    overflow: auto;
    padding-right: 0.2rem;
    scrollbar-gutter: stable;
  }

  .link-editor__form :global(.form-block) {
    grid-template-columns: minmax(0, 9.5rem) minmax(0, 1fr);
    gap: 0.45rem 1.25rem;
    padding-block: 1rem;
  }

  .link-editor__form :global(.form-block .block-copy) {
    max-width: none;
  }

  .link-editor__form :global(.style-grid) {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .link-editor__form :global(.style-grid--buttons) {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .link-editor__preview {
    position: sticky;
    top: 0.5rem;
    display: grid;
    grid-template-rows: auto minmax(0, 1fr);
    gap: 0.5rem;
    min-width: 0;
    min-height: 0;
    height: calc(100dvh - 6.5rem);
    max-height: calc(100dvh - 6.5rem);
  }

  .preview-chrome {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem;
    padding-inline: 0.1rem;
  }

  .preview-label {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .preview-hint {
    font-size: var(--text-xs);
  }

  .preview-frame-wrap {
    position: relative;
    min-height: 0;
    height: 100%;
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-lg);
    background: oklch(0.1 0.008 265);
    overflow: hidden;
  }

  #linkPreviewFrame {
    display: block;
    width: 100%;
    height: 100%;
    border: 0;
    background: transparent;
  }

  @media (max-width: 1100px) {
    .link-editor__form :global(.style-grid),
    .link-editor__form :global(.style-grid--buttons) {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 980px) {
    .link-editor__split {
      grid-template-columns: 1fr;
      min-height: 0;
    }

    .link-editor__form {
      max-height: none;
      overflow: visible;
      padding-right: 0;
    }

    .link-editor__preview {
      position: static;
      height: min(40rem, 72vh);
      max-height: min(40rem, 72vh);
      order: 2;
    }

    .preview-frame-wrap {
      min-height: 22rem;
    }
  }

  @media (max-width: 720px) {
    .link-editor {
      width: calc(100% - 1.25rem);
    }

    .link-editor__form :global(.form-block) {
      grid-template-columns: 1fr;
    }

    .link-editor__form :global(.style-grid),
    .link-editor__form :global(.style-grid--buttons) {
      grid-template-columns: 1fr;
    }
  }
</style>
